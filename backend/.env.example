# Server Configuration
PORT=5000
NODE_ENV=development

# PostgreSQL Connection
DATABASE_URL=postgresql://YOUR_USER:YOUR_PASSWORD@localhost:5432/equipment_tracker

# CORS — Vite frontend origin
CLIENT_ORIGIN=http://localhost:5173

# JWT Auth — change JWT_SECRET to a long random string in production!
JWT_SECRET=change_me_to_a_long_random_secret
JWT_EXPIRES_IN=7d
